rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funções Auxiliares ──────────────────────────────────────────────────
    function isAuth() { return request.auth != null; }
    function userData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    
    function isCoordinator() { 
      let r = userData().role;
      return r == 'coordinator' || r == 'coordenador' || r == 'master' || r == 'diretor';
    }
    function isSupervisor() { return userData().role == 'supervisor'; }
    function isGrowth() { 
      let r = userData().role;
      return r == 'growth_team' || r == 'GROWTH_TEAM' || r == 'growthteam' || r == 'growth team';
    }
    function isAttendant() { return userData().role == 'atendente' || userData().role == 'attendant'; }
    function isGrowthOrAbove() { return isCoordinator() || isGrowth() || isSupervisor(); }
    function isSuperOrAbove()  { return isCoordinator() || isSupervisor(); }

    // ── 1. Usuários ──────────────────────────────────────────────────────────
    match /users/{userId} {
      // Leitura: qualquer autenticado pode listar usuarios (necessario para dropdowns
      // de responsavel no Hub Crescimento, Kanban, Reunioes e Minha Mesa).
      // Escrita: apenas o proprio usuario edita seu perfil, ou coordenador edita qualquer um.
      allow read:  if isAuth();
      allow write: if isAuth() && (request.auth.uid == userId || isCoordinator());
    }

    // ── 2. Leads e CRM ──────────────────────────────────────────────────────
    match /leads/{docId} {
      allow read:  if isAuth() && (isGrowthOrAbove() || (isAttendant() && resource.data.cityId == userData().cityId));
      allow write: if isAuth() && (isCoordinator() || isSupervisor() || (isAttendant() && resource.data.attendantId == request.auth.uid));
    }

    // ── 3. Gestão de Metas e Catálogo ────────────────────────────────────────
    match /sales_channels/{id}         { allow read: if isAuth(); allow write: if isAuth() && isCoordinator(); }
    match /product_categories/{id}     { allow read: if isAuth(); allow write: if isAuth() && isCoordinator(); }
    match /products/{id}               { allow read: if isAuth(); allow write: if isAuth() && isSuperOrAbove(); }
    match /goals_channels/{id}         { allow read: if isAuth(); allow write: if isAuth() && isGrowthOrAbove(); }

    // ── goals_cities: metas mensais por cidade (GestaoMetas, TabMetasCanais) ─
    match /goals_cities/{id}           { allow read: if isAuth(); allow write: if isAuth() && isGrowthOrAbove(); }

    // ── goals_churn: metas de churn por cidade (TabMetasChurn) ───────────────
    match /goals_churn/{id}            { allow read: if isAuth(); allow write: if isAuth() && isGrowthOrAbove(); }

    // ── city_results: fechamentos mensais (GestaoMetas, Apuracao, Laboratorio)
    match /city_results/{id}           { allow read: if isAuth(); allow write: if isAuth() && isGrowthOrAbove(); }

    // ── monthly_bases: base de clientes por mês ──────────────────────────────
    match /monthly_bases/{id}          { allow read: if isAuth(); allow write: if isAuth() && isGrowthOrAbove(); }

    // ── monthly_goals / monthly_cluster_goals (Sala de Guerra, Relatorios) ───
    match /monthly_goals/{id}          { allow read: if isAuth(); allow write: if isAuth() && isCoordinator(); }
    match /monthly_cluster_goals/{id}  { allow read: if isAuth(); allow write: if isAuth() && isCoordinator(); }

    // ── S&OP ─────────────────────────────────────────────────────────────────
    match /sop_simulations/{id}        { allow read: if isAuth(); allow write: if isAuth() && isGrowthOrAbove(); }

    // ── 4. Cidades e Clusters ────────────────────────────────────────────────
    match /cities/{id}                 { allow read: if isAuth(); allow write: if isAuth() && isCoordinator(); }
    match /clusters/{id}               { allow read: if isAuth(); allow write: if isAuth() && isCoordinator(); }

    // ── 5. Hub de Crescimento e Ações ────────────────────────────────────────
    match /growth_plans/{id}           { allow read, write: if isAuth() && isGrowthOrAbove(); }
    match /action_plans/{id}           { allow read, write: if isAuth() && isGrowthOrAbove(); }
    match /action_tasks/{id}           { allow read, write: if isAuth() && isGrowthOrAbove(); }
    match /growth_meetings/{id}        { allow read, write: if isAuth() && isGrowthOrAbove(); }
    match /growth_timeline/{id}        { allow read, write: if isAuth() && isGrowthOrAbove(); }
    match /growth_kpis/{id}            { allow read, write: if isAuth() && isGrowthOrAbove(); }
    match /growth_memory/{id}          { allow read, write: if isAuth() && isGrowthOrAbove(); }
    match /kpis/{id}                   { allow read, write: if isAuth() && isGrowthOrAbove(); }
    match /responsibles/{id}           { allow read, write: if isAuth() && isGrowthOrAbove(); }

    // ── 6. Marketing, Eventos e Estrutura ────────────────────────────────────
    match /sponsorships/{id}           { allow read, write: if isAuth() && isGrowthOrAbove(); }
    match /marketing_actions/{id}      { allow read, write: if isAuth() && isGrowthOrAbove(); }
    // events: agenda pessoal — qualquer autenticado pode criar/editar os próprios
    // e ler eventos onde é participante (participants array-contains uid)
    match /events/{id}                 { allow read, write: if isAuth(); }
    match /growth_events/{id}          { allow read, write: if isAuth() && isGrowthOrAbove(); }

    // ── 7. Churn e Análises ───────────────────────────────────────────────────
    // churn_reasons: motivos de cancelamento (Apuracao, LaboratorioChurn)
    match /churn_reasons/{id}          { allow read: if isAuth(); allow write: if isAuth() && isGrowthOrAbove(); }

    // ── 8. RH e Administrativo ────────────────────────────────────────────────
    // absences: faltas e atestados
    match /absences/{id}               { allow read, write: if isAuth() && isSuperOrAbove(); }
    
    // rh_requests: pedidos de RH (Dashboard, PainelCoordenador, PainelSupervisor)
    match /rh_requests/{id} {
      allow read:   if isAuth() && (isSuperOrAbove() || resource.data.uid == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAuth() && isSuperOrAbove();
      allow delete: if isAuth() && isCoordinator();
    }

    // holidays: feriados (SalaDeGuerra, BancoHoras)
    match /holidays/{id}               { allow read: if isAuth(); allow write: if isAuth() && isCoordinator(); }

    // bank_hours: banco de horas
    match /bank_hours/{id} {
      allow read:   if isAuth() && (isSuperOrAbove() || resource.data.uid == request.auth.uid);
      allow write:  if isAuth() && isSuperOrAbove();
    }

    // petty_cash / petty_cash_cycles: caixa local (DesencaixeSupervisor)
    match /petty_cash/{id}             { allow read, write: if isAuth() && isSuperOrAbove(); }
    match /petty_cash_cycles/{id}      { allow read, write: if isAuth() && isSuperOrAbove(); }

    // Padrão wildcard para subcoleções de absences, rh_requests e cash_register
    match /{path=**}/cash_register/{id} { allow read, write: if isAuth() && isSuperOrAbove(); }

    // ── 9. Conteúdo e Comunicação ─────────────────────────────────────────────
    match /comunicados/{id}            { allow read: if isAuth(); allow write: if isAuth() && isSuperOrAbove(); }
    match /colinhas/{id}               { allow read: if isAuth(); allow write: if isAuth() && (isAttendant() || isSuperOrAbove()); }
    match /messages/{id}               { allow read, write: if isAuth() && isGrowthOrAbove(); }
    match /agenda/{id}                 { allow read: if isAuth(); allow write: if isAuth() && isSuperOrAbove(); }

    // artifacts: conteúdos digitais (ColinhasAtendente)
    match /artifacts/{id}              { allow read: if isAuth(); allow write: if isAuth() && isSuperOrAbove(); }

    // ── 10. Ferramentas e Links ───────────────────────────────────────────────
    match /router_catalog/{id}         { allow read, write: if isAuth(); }
    match /useful_links/{id}           { allow read, write: if isAuth(); }
    match /essential_sheets/{id}       { allow read, write: if isAuth(); }

    // historical_metrics: historico de indicadores (ConfigHistorico)
    match /historical_metrics/{id}     { allow read: if isAuth(); allow write: if isAuth() && isCoordinator(); }

    // settings: configuracoes do sistema (ManualSupervisor, ManualAtendente)
    match /settings/{id}               { allow read: if isAuth(); allow write: if isAuth() && isCoordinator(); }

    // ── 11. Patrocínios e Campanhas ───────────────────────────────────────────
    match /patrocinios/{id}            { allow read, write: if isAuth() && isSuperOrAbove(); }

    // ── 12. E-mail transacional ───────────────────────────────────────────────
    match /mail/{id}                   { allow create: if isAuth(); allow read, delete: if isAuth() && isCoordinator(); }

    // ── 13. Oquei Insights ────────────────────────────────────────────────────
    // Surveys: leitura pública (links de aplicação sem login); escrita autenticada
    match /surveys/{id} {
      allow read:   if true;        // link público lê a campanha sem login
      allow write:  if isAuth();
    }

    // Respostas: leitura autenticada; criação pública (link sem login)
    match /survey_responses/{id} {
      allow read:   if isAuth();
      allow create: if true;   // link público — pesquisador sem login pode enviar
      allow update, delete: if isAuth();
    }

    // Entrevistadores: gerenciados por autenticados; leitura pública (link pessoal)
    match /survey_entrevistadores/{id} {
      allow read:   if true;   // link pessoal lê os dados do entrevistador sem login
      allow write:  if isAuth() && isGrowthOrAbove();
    }

    // Designações de responsável financeiro (Desencaixe)
    match /petty_cash_designacoes/{id} { allow read, write: if isAuth() && isSuperOrAbove(); }

    // Bancos de fornecedores e categorias do Desencaixe
    match /petty_cash_fornecedores/{id} { allow read, write: if isAuth() && isSuperOrAbove(); }
    match /petty_cash_categorias/{id}   { allow read, write: if isAuth() && isSuperOrAbove(); }
  }
}
