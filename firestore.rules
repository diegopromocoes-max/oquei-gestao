rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function userData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    
    function isCoordinator() { 
      let r = userData().role;
      return r == 'coordinator' || r == 'coordenador' || r == 'master' || r == 'diretor';
    }
    function isSupervisor() { return userData().role == 'supervisor'; }
    function isGrowth() { return userData().role == 'growth_team' || userData().role == 'GROWTH_TEAM'; }
    function isAttendant() { return userData().role == 'atendente' || userData().role == 'attendant'; }

    match /users/{userId} {
      allow get: if isAuth();
      allow list: if isAuth() && (isCoordinator() || isGrowth() || isSupervisor());
      allow write: if isAuth() && isCoordinator();
    }

    match /leads/{docId} {
      allow read: if isAuth() && (isCoordinator() || isGrowth() || isSupervisor() || (isAttendant() && resource.data.cityId == userData().cityId));
      allow write: if isAuth() && (isCoordinator() || isSupervisor() || (isAttendant() && resource.data.attendantId == request.auth.uid));
    }

    // Regras gerais de metas
    match /goals_channels/{id} { allow read: if isAuth() && (isCoordinator() || isSupervisor()); allow write: if isAuth() && isCoordinator(); }
    match /product_categories/{id} { allow read: if isAuth() && (isCoordinator() || isSupervisor()); allow write: if isAuth() && isCoordinator(); }
    
    // Hub de Crescimento
    match /growth_plans/{id} { allow read, write: if isAuth() && (isCoordinator() || isGrowth() || isSupervisor()); }
    match /action_plans/{id} { allow read, write: if isAuth() && (isCoordinator() || isGrowth() || isSupervisor()); }
    
    // Outras coleções (Caixa, RH, etc) - Leitura para envolvidos
    match /{path=**}/absences/{id} { allow read, write: if isAuth() && (isCoordinator() || isSupervisor()); }
    match /{path=**}/cash_register/{id} { allow read, write: if isAuth() && (isCoordinator() || isSupervisor()); }
    match /cities/{id} { allow read: if isAuth(); allow write: if isAuth() && isCoordinator(); }
    match /colinhas/{id} { allow read: if isAuth(); allow write: if isAuth() && (isAttendant() || isCoordinator()); }
  }
}